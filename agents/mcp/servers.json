{
  "mcpServers": {
    "grep_app": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "opentelemetry-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["opentelemetry-mcp"],
      "env": {
        "BACKEND_TYPE": "jaeger",
        "BACKEND_URL": "http://localhost:16686"
      }
    }
  }
}
