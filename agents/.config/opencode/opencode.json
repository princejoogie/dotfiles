{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": [
    "opencode-with-claude"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy"
      }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "Default MLX Model"
        }
      }
    }
  },
  "agent": {
    "design": {
      "mode": "subagent",
      "description": "Designs elegant and intuitive user interfaces",
      "model": "google/gemini-3.1-pro-preview",
      "options": {}
    }
  },
  "mcp": {
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "opentelemetry-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "opentelemetry-mcp"
      ],
      "enabled": true,
      "environment": {
        "BACKEND_TYPE": "jaeger",
        "BACKEND_URL": "http://localhost:16686"
      }
    }
  }
}
