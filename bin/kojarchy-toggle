#!/bin/bash

# Toggle persistent Kojarchy feature flags on or off.

set -euo pipefail

ENABLED_NOTIFICATION=""
DISABLED_NOTIFICATION=""

while [[ $# -gt 1 ]]; do
  case "$1" in
    --enabled-notification) ENABLED_NOTIFICATION="$2"; shift 2 ;;
    --disabled-notification) DISABLED_NOTIFICATION="$2"; shift 2 ;;
    *) break ;;
  esac
done

FLAG_NAME="${1:-}"
FLAG_DIR="$HOME/.local/state/kojarchy/toggles"
FLAG="$FLAG_DIR/$FLAG_NAME"

if [[ -z "$FLAG_NAME" ]]; then
  echo "Usage: kojarchy-toggle [--enabled-notification msg] [--disabled-notification msg] <flag-name>" >&2
  exit 1
fi

mkdir -p "$FLAG_DIR"

if [[ -f "$FLAG" ]]; then
  rm -f "$FLAG"
  [[ -n "$DISABLED_NOTIFICATION" ]] && notify-send -u low "$DISABLED_NOTIFICATION"
else
  touch "$FLAG"
  [[ -n "$ENABLED_NOTIFICATION" ]] && notify-send -u low "$ENABLED_NOTIFICATION"
fi
