#!/bin/bash

# Install an npx-backed wrapper command into ~/.local/bin.
# Usage: kojarchy-npx-install <package> [command-name]

if [[ -z ${1:-} ]]; then
  echo "Usage: kojarchy-npx-install <package> [command-name]"
  exit 1
fi

package=$1
command=${2:-$1}

mkdir -p "$HOME/.local/bin"

cat > "$HOME/.local/bin/$command" <<EOF
#!/bin/bash
exec mise exec node@latest -- npx --yes $package "\$@"
EOF

chmod +x "$HOME/.local/bin/$command"
