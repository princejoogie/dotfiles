#!/usr/bin/sh

# Check if URL argument is provided
if [ $# -eq 0 ]; then
  echo "Error: No URL provided"
  echo "Usage: $0 <youtube_url>"
  exit 1
fi

URL="$1"

echo "[LOG] Cleaning up temporary files..."
rm -rf /tmp/transcript.mp3* >/dev/null 2>&1

echo "[LOG] Downloading audio..."
yt-dlp --extract-audio --audio-format mp3 --output /tmp/transcript.mp3 "$URL" >/dev/null 2>&1

echo "[LOG] Generating transcript..."
whisper-cli -otxt -m ~/documents/codes/whisper.cpp/models/ggml-small.bin -l auto /tmp/transcript.mp3 >/dev/null 2>&1

echo "[LOG] Summarizing transcript..."
opencode run "summarize the provided transcript. the file is located at \`/tmp/transcript.mp3.txt\`"
