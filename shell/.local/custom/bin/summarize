#!/usr/bin/sh

main() {
  # Check if URL argument is provided
  if [ $# -eq 0 ]; then
    echo "Error: No URL provided"
    echo "Usage: $0 <youtube_url>"
    exit 1
  fi

  URL="$1"

  run_with_log_window "Cleaning up temporary files" 0 rm -rf /tmp/transcript.mp3*

  run_with_log_window "Downloading audio" 3 yt-dlp --extract-audio --audio-format mp3 --output /tmp/transcript.mp3 "$URL"

  run_with_log_window "Generating transcript" 3 whisper-cli -otxt -m ~/documents/codes/whisper.cpp/models/ggml-small.bin -l auto /tmp/transcript.mp3

  echo "[LOG] Summarizing transcript..."
  opencode run "summarize the provided transcript. do not ask follow up questions. you should do what you're about to ask since this convesation will not be continued and only your output will be used. the transcript is located at \`/tmp/transcript.mp3.txt\`"
}

render_last_lines() {
  line_count="$1"
  tail -n "$line_count" "$2" 2>/dev/null | awk -v max="$line_count" '
    { lines[NR] = $0 }
    END {
      for (i = 1; i <= max - NR; i++) print ""
      for (i = 1; i <= NR; i++) print lines[i]
    }
  '
}

run_with_log_window() {
  message="$1"
  line_count="$2"
  shift 2

  printf '[LOG] %s...\n' "$message"

  if [ ! -t 1 ]; then
    "$@" >/dev/null 2>&1
    status=$?
    marker='x'
    if [ "$status" -eq 0 ]; then
      marker='✓'
    fi
    printf '\033[1A\033[2K\r[LOG] %s %s\n' "$message" "$marker"
    return $status
  fi

  if [ "$line_count" -eq 0 ]; then
    "$@" >/dev/null 2>&1
    status=$?
    marker='x'
    if [ "$status" -eq 0 ]; then
      marker='✓'
    fi
    printf '\033[1A\033[2K\r[LOG] %s %s\n' "$message" "$marker"
    return $status
  fi

  tmp_file=$(mktemp)
  "$@" >"$tmp_file" 2>&1 &
  pid=$!

  i=0
  while [ "$i" -lt "$line_count" ]; do
    printf '\n'
    i=$((i + 1))
  done

  while kill -0 "$pid" 2>/dev/null; do
    printf '\033[%sA' "$line_count"
    render_last_lines "$line_count" "$tmp_file" | while IFS= read -r line; do
      printf '\033[2K\r  %s\n' "$line"
    done
    sleep 0.2
  done

  wait "$pid"
  status=$?

  marker='x'
  if [ "$status" -eq 0 ]; then
    marker='✓'
  fi

  printf '\033[%sA\033[2K\r[LOG] %s %s\n' "$((line_count + 1))" "$message" "$marker"
  printf '\033[%sM' "$line_count"

  rm -f "$tmp_file"
  return $status
}

main "$@"
