#!/usr/bin/sh

main() {
  # Check if URL argument is provided
  if [ $# -eq 0 ]; then
    echo "Error: No URL provided" >&2
    echo "Usage: $0 <youtube_url>" >&2
    exit 1
  fi

  URL="$1"

  run_with_log_window "Cleaning up temporary files" 0 - rm -rf /tmp/transcript.mp3*

  run_with_log_window "Downloading audio" 3 - yt-dlp --extract-audio --audio-format mp3 --output /tmp/transcript.mp3 "$URL"

  run_with_log_window "Generating transcript" 3 - whisper-cli -otxt -m ~/documents/codes/whisper.cpp/models/ggml-small.bin -l auto /tmp/transcript.mp3

  echo "[LOG] Summarizing transcript..." >&2
  opencode run "summarize the provided transcript. do not ask follow up questions. You should do what you're about to ask since this convesation will not be continued and only your output will be used. Do not mention anything like 'the transcript says...' etc. Just proceed with the summarization immediately. The transcript is located at \`/tmp/transcript.mp3.txt\`."
}

render_last_lines() {
  line_count="$1"
  tail -n "$line_count" "$2" 2>/dev/null | awk -v max="$line_count" '
    { lines[NR] = $0 }
    END {
      for (i = 1; i <= max - NR; i++) print ""
      for (i = 1; i <= NR; i++) print lines[i]
    }
  '
}

run_with_log_window() {
  message="$1"
  line_count="$2"
  output_file="$3"
  shift 3

  if [ "$output_file" = '-' ]; then
    output_file=''
  fi

  printf '[LOG] %s...\n' "$message" >&2

  tmp_file=$(mktemp)

  if [ ! -t 2 ]; then
    "$@" >"$tmp_file" 2>&1
    status=$?
    marker='x'
    if [ "$status" -eq 0 ]; then
      marker='✓'
    fi
    if [ -n "$output_file" ]; then
      cp "$tmp_file" "$output_file"
    fi
    printf '[LOG] %s %s\n' "$message" "$marker" >&2
    rm -f "$tmp_file"
    return $status
  fi

  if [ "$line_count" -eq 0 ]; then
    "$@" >"$tmp_file" 2>&1
    status=$?
    marker='x'
    if [ "$status" -eq 0 ]; then
      marker='✓'
    fi
    if [ -n "$output_file" ]; then
      cp "$tmp_file" "$output_file"
    fi
    printf '\033[1A\033[2K\r[LOG] %s %s\n' "$message" "$marker" >&2
    rm -f "$tmp_file"
    return $status
  fi

  "$@" >"$tmp_file" 2>&1 &
  pid=$!

  i=0
  while [ "$i" -lt "$line_count" ]; do
    printf '\n' >&2
    i=$((i + 1))
  done

  while kill -0 "$pid" 2>/dev/null; do
    printf '\033[%sA' "$line_count" >&2
    render_last_lines "$line_count" "$tmp_file" | while IFS= read -r line; do
      printf '\033[2K\r  %s\n' "$line" >&2
    done
    sleep 0.2
  done

  wait "$pid"
  status=$?

  marker='x'
  if [ "$status" -eq 0 ]; then
    marker='✓'
  fi

  if [ -n "$output_file" ]; then
    cp "$tmp_file" "$output_file"
  fi

  printf '\033[%sA\033[2K\r[LOG] %s %s\n' "$((line_count + 1))" "$message" "$marker" >&2
  printf '\033[%sM' "$line_count" >&2

  rm -f "$tmp_file"
  return $status
}

main "$@"
