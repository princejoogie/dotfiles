{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/**": "allow"
    }
  },
  "mcp": {
    "playwriter": {
      "type": "local",
      "command": ["npx", "-y", "playwriter@latest"]
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "computer-use": {
      "type": "local",
      "command": ["codex", "mcp-server"]
    }
  }
}
