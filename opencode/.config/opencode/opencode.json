{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/**": "allow"
    }
  },
  "provider": {
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "Default MLX Model"
        }
      }
    }
  },
  "agent": {
    "design": {
      "mode": "subagent",
      "description": "Designs elegant and intuitive user interfaces",
      "model": "google/gemini-3.1-pro-preview",
      "options": {},
      "permission": {}
    }
  },
  "mcp": {
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
